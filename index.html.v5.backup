<!DOCTYPE html>
<html lang="he">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>רובושף</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
<div class="container">

    <!-- Welcome Screen -->
    <div id="welcome">
        <h1>🤖 רובושף</h1>
        <button id="recipeButton">🍲 מתחילים</button>
    </div>

    <!-- Persistent header shown on screens 1-5 -->
    <div id="appHeader" style="display:none;">
        <div class="app-logo">🤖 רובושף</div>
    </div>

    <!-- Progress indicator shown on screens 1-4 -->
    <div id="progressBar" style="display:none;">
        <div class="progress-dots">
            <span class="dot" id="dot1"></span>
            <span class="dot" id="dot2"></span>
            <span class="dot" id="dot3"></span>
            <span class="dot" id="dot4"></span>
        </div>
        <div class="progress-label" id="progressText">שלב 1 מתוך 4</div>
    </div>

    <!-- Screen 1: Ingredients -->
    <div id="step1" style="display:none;">
        <h2>🥚 מה יש בבית?</h2>
        <div class="checkbox-list">
            <label><input type="checkbox" value="ביצים"> 🥚 ביצים</label>
            <label><input type="checkbox" value="גבינה"> 🧀 גבינה</label>
            <label><input type="checkbox" value="פסטה"> 🍝 פסטה</label>
            <label><input type="checkbox" value="לחם"> 🍞 לחם</label>
            <label><input type="checkbox" value="שוקולד"> 🍫 שוקולד</label>
            <label><input type="checkbox" value="בננה"> 🍌 בננה</label>
            <label><input type="checkbox" value="תפוח"> 🍎 תפוח</label>
            <label><input type="checkbox" value="עגבנייה"> 🍅 עגבנייה</label>
            <label><input type="checkbox" value="מלפפון"> 🥒 מלפפון</label>
            <label><input type="checkbox" value="חלב"> 🥛 חלב</label>
            <label><input type="checkbox" value="דבש"> 🍯 דבש</label>
            <label><input type="checkbox" value="תירס"> 🌽 תירס</label>
            <label><input type="checkbox" value="תפוח אדמה"> 🥔 תפוח אדמה</label>
            <label><input type="checkbox" value="עוף"> 🍗 עוף</label>
        </div>
        <div class="nav-buttons">
            <button class="btn-next" onclick="showStep(2)">⬅️ הבא</button>
        </div>
    </div>

    <!-- Screen 2: Taste -->
    <div id="step2" style="display:none;">
        <h2>🍫 מה בא לך?</h2>
        <div class="radio-list">
            <label><input type="radio" name="type" value="מתוק"> 🍫 מתוק</label>
            <label><input type="radio" name="type" value="מלוח"> 🧂 מלוח</label>
        </div>
        <div class="nav-buttons">
            <button class="btn-back" onclick="showStep(1)">חזור ➡️</button>
            <button class="btn-next" onclick="showStep(3)">⬅️ הבא</button>
        </div>
    </div>

    <!-- Screen 3: Time -->
    <div id="step3" style="display:none;">
        <h2>⏰ כמה זמן יש לך?</h2>
        <select id="time">
            <option value="5">5 דקות</option>
            <option value="10">10 דקות</option>
            <option value="20">20 דקות</option>
            <option value="30">30 דקות+</option>
        </select>
        <div class="nav-buttons">
            <button class="btn-back" onclick="showStep(2)">חזור ➡️</button>
            <button class="btn-next" onclick="showStep(4)">⬅️ הבא</button>
        </div>
    </div>

    <!-- Screen 4: Cooking method -->
    <div id="step4" style="display:none;">
        <h2>🔥 איך מכינים?</h2>
        <select id="method">
            <option value="">🍽️ כל שיטה</option>
            <option value="גז">🔥 גז</option>
            <option value="תנור">🔥 תנור</option>
            <option value="מיקרוגל">⚡ מיקרוגל</option>
            <option value="בלי בישול">🥗 בלי בישול</option>
        </select>
        <div class="nav-buttons">
            <button class="btn-back" onclick="showStep(3)">חזור ➡️</button>
            <button class="btn-next" onclick="showStep(5)">⬅️ הבא</button>
        </div>
    </div>

    <!-- Screen 5: Result -->
    <div id="step5" style="display:none;">
        <button id="findRecipe">🔍 מצא לי מתכון</button>
        <div class="secondary-buttons">
            <button id="surpriseRecipe">🎲 הפתע אותי</button>
            <button id="anotherRecipe">🔄 עוד רעיון</button>
            <button id="resetApp">🏠 התחל מחדש</button>
        </div>
        <div id="recipeResult"></div>
        <!-- Logo placeholder — future RoboChef logo goes here -->
        <div id="logoPlaceholder"></div>
    </div>

</div>
<script src="recipes.js"></script>
<script src="script.js"></script>
</body>
</html>
