* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    font-family: Arial, sans-serif;
    background: #c8f0ff;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 20px 16px 40px;
}

.container {
    background: white;
    border-radius: 20px;
    padding: 30px 20px;
    width: 100%;
    max-width: 480px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
    text-align: center;
}

/* ── Welcome ── */

#welcome h1 {
    font-size: 2.4rem;
    margin-bottom: 32px;
    color: #222;
}

/* ── Persistent header ── */

#appHeader {
    margin-bottom: 14px;
}

.app-logo {
    font-size: 1.1rem;
    font-weight: bold;
    color: #555;
}

/* ── Progress bar ── */

#progressBar {
    margin-bottom: 24px;
}

.progress-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 6px;
}

.dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #ddd;
    display: inline-block;
    transition: background 0.25s;
}

.dot.active {
    background: orange;
}

.progress-label {
    font-size: 0.8rem;
    color: #aaa;
}

/* ── Screen headings ── */

h2 {
    font-size: 1.3rem;
    margin-bottom: 20px;
    color: #222;
}

/* ── Ingredient checkboxes ── */

.checkbox-list {
    text-align: right;
    margin-bottom: 24px;
}

.checkbox-list label {
    display: block;
    padding: 11px 4px;
    font-size: 1rem;
    cursor: pointer;
    border-bottom: 1px solid #f0f0f0;
}

.checkbox-list label:last-child {
    border-bottom: none;
}

/* ── Taste radio buttons ── */

.radio-list {
    text-align: right;
    margin-bottom: 24px;
}

.radio-list label {
    display: block;
    padding: 14px 4px;
    font-size: 1.1rem;
    cursor: pointer;
    border-bottom: 1px solid #f0f0f0;
}

.radio-list label:last-child {
    border-bottom: none;
}

/* ── Select dropdowns ── */

select {
    width: 100%;
    padding: 14px 12px;
    font-size: 1rem;
    border-radius: 12px;
    border: 1px solid #ddd;
    margin-bottom: 24px;
    background: white;
}

/* ── Navigation buttons (back / next) ── */

.nav-buttons {
    display: flex;
    justify-content: space-between;
    gap: 10px;
}

.btn-next {
    margin-left: auto;
    border: none;
    border-radius: 30px;
    padding: 14px 28px;
    font-size: 1rem;
    cursor: pointer;
    background: orange;
    color: white;
    font-weight: bold;
    min-width: 110px;
}

.btn-back {
    border: none;
    border-radius: 30px;
    padding: 14px 20px;
    font-size: 1rem;
    cursor: pointer;
    background: #efefef;
    color: #555;
    font-weight: bold;
}

/* ── Welcome button + main find button ── */

#recipeButton,
#findRecipe {
    display: block;
    width: 100%;
    border: none;
    border-radius: 30px;
    padding: 18px;
    font-size: 1.2rem;
    cursor: pointer;
    background: orange;
    color: white;
    font-weight: bold;
    margin-bottom: 16px;
}

/* ── Secondary circular buttons ── */

.secondary-buttons {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 24px;
    flex-wrap: wrap;
}

.secondary-buttons button {
    border: none;
    border-radius: 30px;
    padding: 10px 16px;
    font-size: 0.85rem;
    cursor: pointer;
    background: #e8e8e8;
    color: #444;
    font-weight: bold;
    flex: 1;
    min-width: 90px;
}

/* ── Recipe result card ── */

.recipe-card {
    margin-top: 20px;
    background: #fff8d6;
    padding: 20px;
    border-radius: 15px;
    text-align: right;
}

.recipe-card h2 {
    text-align: center;
    font-size: 1.2rem;
    margin-bottom: 12px;
}

.recipe-card p {
    margin-bottom: 8px;
    font-size: 0.95rem;
}

.recipe-card h3 {
    margin: 12px 0 8px;
    font-size: 1rem;
}

.recipe-card ol {
    direction: rtl;
    padding-right: 20px;
    padding-left: 0;
    text-align: right;
}

.recipe-card ol li {
    margin-bottom: 6px;
    font-size: 0.95rem;
}

/* ── Ingredient status in recipe card ── */

.has-all {
    background: #d4edda;
    color: #1a5c2e;
    border: 1px solid #28a745;
    border-radius: 8px;
    padding: 8px 12px;
    margin-bottom: 12px;
    font-size: 0.9rem;
    text-align: right;
}

.has-ingredients {
    background: #d4edda;
    color: #1a5c2e;
    border: 1px solid #28a745;
    border-radius: 8px;
    padding: 8px 12px;
    margin-bottom: 6px;
    font-size: 0.9rem;
    text-align: right;
}

.missing-msg {
    background: #fff3cd;
    color: #7a5c00;
    border: 1px solid #ffc107;
    border-radius: 8px;
    padding: 8px 12px;
    margin-bottom: 12px;
    font-size: 0.9rem;
    text-align: right;
}

/* ── Logo placeholder ── */

#logoPlaceholder {
    height: 60px;
    margin-top: 28px;
}

/* ── Desktop adjustments ── */

@media (min-width: 540px) {
    body {
        align-items: center;
        padding: 40px 20px;
    }

    .container {
        padding: 40px 36px;
    }

    #welcome h1 {
        font-size: 2.8rem;
    }
}
